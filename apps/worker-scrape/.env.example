# Environment Variables — apps/worker-scrape
# Copy to .env and fill in real values.

NODE_ENV=development

MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/commerce-orchestrator?retryWrites=true&w=majority

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

ENCRYPTION_KEY=replace-with-32-byte-hex-string

# Scrape-specific
PLAYWRIGHT_HEADLESS=true
SCRAPE_CONCURRENCY=2
PROXY_URL=

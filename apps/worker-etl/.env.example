# Environment Variables — apps/worker
# Copy this file to .env and fill in real values. Never commit .env to git.

# Server
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/commerce-orchestrator?retryWrites=true&w=majority

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Encryption (must match apps/api ENCRYPTION_KEY)
ENCRYPTION_KEY=replace-with-32-byte-hex-string

# Concurrency
WORKER_ETL_CONCURRENCY=5
WORKER_SCRAPE_CONCURRENCY=2

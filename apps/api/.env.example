# Environment Variables — apps/api
# Copy this file to .env and fill in real values. Never commit .env to git.

# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/commerce-orchestrator?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace-with-a-secure-random-string-min-32-chars
JWT_EXPIRES_IN=7d

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Encryption (for AES-256-GCM credential encryption)
ENCRYPTION_KEY=replace-with-32-byte-hex-string
